{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (vcpkg toolchain)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_PATH}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "RUDP_BUILD_TESTS": "ON"
      }
    }
  ]
}
