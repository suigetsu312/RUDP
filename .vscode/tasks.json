{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure CMake preset default",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "default"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build unit_tests",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "unit_tests"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Configure CMake preset default",
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build rudp_app",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "rudp_app"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Configure CMake preset default",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
