{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug unit_tests (all)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/unit_tests",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build unit_tests"
    },
    {
      "name": "Debug current failing session test",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/unit_tests",
      "args": [
        "--gtest_filter=SessionSkeletonTest.EstablishedConnectionReceivesDataThenResetProducesDataAndResetEvents"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build unit_tests"
    },
    {
      "name": "Debug rudp_app (main)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/rudp_app",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build rudp_app"
    }
  ]
}
