# Transport timing
RUDP_TRANSPORT_INITIAL_RTO_MS=250
RUDP_TRANSPORT_MAX_RTO_MS=4000
RUDP_TRANSPORT_MAX_RETRANSMIT_COUNT=5
RUDP_TRANSPORT_HANDSHAKE_LINGER_MS=1000
RUDP_TRANSPORT_KEEPALIVE_IDLE_MS=5000
RUDP_TRANSPORT_IDLE_TIMEOUT_MS=15000

# Runtime defaults
RUDP_RUNTIME_SERVER_BIND_ADDRESS=127.0.0.1
RUDP_RUNTIME_SERVER_PORT=9000
RUDP_RUNTIME_CLIENT_SERVER_ADDRESS=127.0.0.1
RUDP_RUNTIME_CLIENT_SERVER_PORT=9000
RUDP_RUNTIME_CLIENT_BIND_ADDRESS=0.0.0.0
RUDP_RUNTIME_SOCKET_BUFFER_SIZE=1500
RUDP_RUNTIME_SERVER_LOOP_SLEEP_US=10000
RUDP_RUNTIME_CLIENT_SELECT_TIMEOUT_US=10000
RUDP_RUNTIME_CLIENT_POLL_BUDGET=8
RUDP_RUNTIME_SERVER_LOG_PATH=logs/rudp_server.log
RUDP_RUNTIME_CLIENT_LOG_PATH=logs/rudp_client.log
