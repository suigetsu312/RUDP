#!/usr/bin/env zsh

set -euo pipefail

SCRIPT_DIR=${0:A:h}
REPO_ROOT=${SCRIPT_DIR:h}
SCRIPT_NAME=${0:t}
BOOTSTRAP_FILE="${REPO_ROOT}/tmp/client.commands"
DEFAULT_CLIENT_COMMAND=${RUDP_CLIENT_COMMAND:-"/spawn stream 4 0 5 burst"}
DEFAULT_BUILD_POLICY=${RUDP_DOCKER_BUILD:-auto}
DEFAULT_REORDER_DELAY=${RUDP_NETEM_REORDER_DELAY:-20ms}
EXPERIMENT_NAME_OVERRIDE=${RUDP_EXPERIMENT_NAME:-}
RUN_ID=""
EXPERIMENT_NAME=""
LOG_DIR=""

usage() {
  cat <<EOF
Usage:
  ${SCRIPT_NAME} baseline
  ${SCRIPT_NAME} delay <duration>
  ${SCRIPT_NAME} loss <spec...>
  ${SCRIPT_NAME} reorder <spec...>
  ${SCRIPT_NAME} custom <netem args...>
  ${SCRIPT_NAME} down

Examples:
  ${SCRIPT_NAME} baseline
  ${SCRIPT_NAME} delay 100ms
  ${SCRIPT_NAME} loss 5%
  ${SCRIPT_NAME} reorder 25% 50%
  ${SCRIPT_NAME} custom delay 80ms loss 3% reorder 20% 50%

Environment:
  RUDP_CLIENT_COMMAND   bootstrap command written to tmp/client.commands
                        default: ${DEFAULT_CLIENT_COMMAND}
  RUDP_EXPERIMENT_NAME  override experiment/log directory name
  RUDP_DOCKER_BUILD     auto|always|never
                        auto: build only if images are missing
                        always: rebuild before compose up
                        never: skip rebuild and require existing images
  RUDP_NETEM_REORDER_DELAY
                        baseline delay applied before reorder
                        default: ${DEFAULT_REORDER_DELAY}
EOF
}

require_tool() {
  local tool="$1"
  if ! command -v "${tool}" >/dev/null 2>&1; then
    echo "missing required tool: ${tool}" >&2
    exit 1
  fi
}

write_bootstrap() {
  mkdir -p "${REPO_ROOT}/tmp"
  cat > "${BOOTSTRAP_FILE}" <<EOF
# Auto-generated by ${SCRIPT_NAME}
${DEFAULT_CLIENT_COMMAND}
EOF
}

init_log_dir() {
  local experiment="$1"
  RUN_ID="$(date +%Y%m%d%H%M%S)"
  EXPERIMENT_NAME="${EXPERIMENT_NAME_OVERRIDE:-${experiment}}"
  LOG_DIR="${REPO_ROOT}/logs/${EXPERIMENT_NAME}/${RUN_ID}"
  mkdir -p "${LOG_DIR}"
  export RUDP_RUNTIME_SERVER_LOG_PATH="/workspace/logs/${EXPERIMENT_NAME}/${RUN_ID}/server.log"
  export RUDP_RUNTIME_CLIENT_LOG_PATH="/workspace/logs/${EXPERIMENT_NAME}/${RUN_ID}/client.log"
  export RUDP_CLIENT_BOOTSTRAP_FILE="/workspace/tmp/client.commands"
}

image_exists() {
  local image="$1"
  docker image inspect "${image}" >/dev/null 2>&1
}

ensure_images() {
  case "${DEFAULT_BUILD_POLICY}" in
    always)
      echo "--- building images (policy=always)"
      docker compose build server client
      ;;
    never)
      if ! image_exists rudp-server || ! image_exists rudp-client; then
        echo "required images missing and RUDP_DOCKER_BUILD=never" >&2
        exit 1
      fi
      ;;
    auto)
      if ! image_exists rudp-server || ! image_exists rudp-client; then
        echo "--- images missing; building once (policy=auto)"
        docker compose build server client
      fi
      ;;
    *)
      echo "unknown RUDP_DOCKER_BUILD policy: ${DEFAULT_BUILD_POLICY}" >&2
      exit 1
      ;;
  esac
}

compose_up() {
  ensure_images
  docker compose up -d --no-build server client
}

compose_down() {
  docker compose down
}

clear_netem() {
  local service="$1"
  docker compose exec -T "${service}" sh -lc \
    "tc qdisc del dev eth0 root 2>/dev/null || true"
}

apply_netem() {
  local service="$1"
  shift
  docker compose exec -T "${service}" tc qdisc replace dev eth0 root netem "$@"
}

show_status() {
  echo "--- experiment"
  echo "name=${EXPERIMENT_NAME} run_id=${RUN_ID}"
  echo "log_dir=${LOG_DIR}"
  echo
  echo "--- docker compose ps"
  docker compose ps
  echo
  echo "--- server logs (tail)"
  docker compose logs --tail=20 server || true
  echo
  echo "--- client logs (tail)"
  docker compose logs --tail=20 client || true
}

main() {
  require_tool docker

  local mode="${1:-}"
  shift || true

  case "${mode}" in
    baseline)
      write_bootstrap
      init_log_dir baseline
      compose_up
      clear_netem server
      clear_netem client
      show_status
      ;;
    delay)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      write_bootstrap
      init_log_dir "delay-$1"
      compose_up
      apply_netem server delay "$1"
      apply_netem client delay "$1"
      show_status
      ;;
    loss)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      write_bootstrap
      init_log_dir "loss-${1//\%/pct}"
      compose_up
      apply_netem server loss "$@"
      apply_netem client loss "$@"
      show_status
      ;;
    reorder)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      write_bootstrap
      init_log_dir "reorder-${1//\%/pct}"
      compose_up
      apply_netem server delay "${DEFAULT_REORDER_DELAY}" reorder "$@"
      apply_netem client delay "${DEFAULT_REORDER_DELAY}" reorder "$@"
      show_status
      ;;
    custom)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      write_bootstrap
      init_log_dir custom
      compose_up
      apply_netem server "$@"
      apply_netem client "$@"
      show_status
      ;;
    down)
      compose_down
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      echo "unknown mode: ${mode}" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
